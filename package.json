{
  "name": "cat-odyssey-ricochet",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node scripts/prune-build-assets.mjs --target dist/game && npm run build:standalone",
    "build:standalone": "vite build --config vite.standalone.config.mjs",
    "test": "vitest run",
    "test:localization": "vitest run tests/localization",
    "test:physics": "vitest run tests/physics",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:pack": "node scripts/validate-pack.mjs",
    "validate:english:source": "node scripts/check-english-coverage.mjs --source-only",
    "validate:english": "node scripts/check-english-coverage.mjs",
    "smoke:localization": "node scripts/run-localization-smoke.mjs",
    "package:lemgame": "npm run build && node scripts/package-lem.mjs",
    "package:lem": "npm run package:lemgame",
    "qa": "npm run test && npm run validate:content && npm run validate:english:source && npm run build && npm run validate:pack"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "jszip": "3.10.1",
    "playwright-core": "^1.61.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
